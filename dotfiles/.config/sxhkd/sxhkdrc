#
# wm independent hotkeys
#

# Brave
super + b
	/var/lib/flatpak/exports/bin/com.brave.Browser 

# Files
super + shift + f
	nemo

# Code
super + c
	code 

# terminal emulator
super + Return
	~/.local/kitty.app/bin/kitty

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

#
# bspwm hotkeys
#

# quit/restart bspwm
super + alt + {q,r}
	bspc {quit,wm -r}

# close and kill
super + {_,shift + }w
	bspc node -{c,k}

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# send the newest marked node to the newest preselected node
#super + y
#	bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest window
#super + g
#	bspc node -s biggest.window

#
# state/flags
#

# Capturas
super + shift + s
	flameshot gui && paplay /etc/share/bspwmSounds/camera-shutter.oga
Print
	flameshot screen

# set the window state
super + {t,shift + t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# set the node flags
#super + ctrl + {m,x,y,z}
#	bspc node -g {marked,locked,sticky,private}

#
# Enfocar ventanas
#
super + Right
	bspc node -f east.local

super + Left
	bspc node -f west.local

super + Up
	bspc node -f north.local
super + Down
	bspc node -f south.local

#
# Intercambiar ventanas (swap)
#

super + shift + Right
	bspc node -s east.local

super + shift + Left
	bspc node -s west.local

super + shift + Up
	bspc node -s north.local

super + shift + Down
	bspc node -s south.local

#
# volume
#

super + KP_Add
	wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ && paplay /etc/share/bspwmSounds/volume.oga

super + KP_Subtract
	wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && paplay /etc/share/bspwmSounds/volume.oga

